        "name": "_analyze_sentiment",
        "ast_hash": "sha256:f9a3cb2565a33180",
        "loc": 3,
        "source": "def _analyze_sentiment(self, text):\n        blob = TextBlob(text)\n        return blob.sentiment.polarity"
      },
      {
        "name": "_to_structured_output",
        "ast_hash": "sha256:52b231b9a20f2bda",
        "loc": 6,
        "source": "def _to_structured_output(self, sentiments):\n        return {\n            \"source_agent\": self.__class__.__name__,\n            \"confidence_score\": 0.8,\n            \"data\": sentiments,\n        }"
      },
