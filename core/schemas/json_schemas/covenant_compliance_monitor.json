{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$defs": {
    "Covenant": {
      "properties": {
        "covenant_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Covenant Type"
        },
        "metric_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Metric Name"
        },
        "threshold_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold Value"
        },
        "threshold_operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold Operator"
        },
        "current_calculated_value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Current Calculated Value"
        },
        "compliance_status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Compliance Status"
        },
        "cure_period_days": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cure Period Days"
        }
      },
      "title": "Covenant",
      "type": "object"
    }
  },
  "properties": {
    "credit_agreement_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Credit Agreement Id"
    },
    "covenants": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Covenant"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Covenants"
    }
  },
  "title": "CovenantComplianceMonitor",
  "type": "object"
}